# ============================================
# SMARTLINK PILOT — Production Environment Template
# ============================================
# Copy this file to .env and fill in the real values.
# For Vercel: Add these in Settings → Environment Variables

# ---- Authentication (NextAuth) ----
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="https://www.smartlinkpilot.com"

# ---- Database (Supabase / Postgres) ----
# Obtain from Supabase → Settings → Database → Connection string → Prisma
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?pgbouncer=true"
# (Optional) Direct connection for migrations
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# ---- Google OAuth (Optional for Social Login) ----
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Android OAuth client ID (for native Google Sign-In idToken audience verification)
# Create at console.cloud.google.com → APIs & Services → Credentials → Android client
GOOGLE_ANDROID_CLIENT_ID=""

# ---- Stripe (Payments) ----
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ---- OpenAI (AI Writer & Assistant) ----
OPENAI_API_KEY=""

# ---- Pesapal currency (avoids USD per-transaction limit) ----
# Send amounts in TZS to stay within Pesapal account limits
# Update PESAPAL_CURRENCY_RATE to the current USD→TZS exchange rate
PESAPAL_CURRENCY="TZS"
PESAPAL_CURRENCY_RATE="2600"

# ---- Email (Resend) ----
# Get your API key from resend.com/api-keys
# Senders: mclean@smartlinkpilot.com | support@smartlinkpilot.com | info@smartlinkpilot.com
RESEND_API_KEY=""

# ---- IndexNow (instant search engine indexing — Bing, Yandex, Google) ----
# Generate a 32-char hex key: node -e "require('crypto').randomBytes(16).toString('hex')|process.stdout.write"
# Then add the same key to Bing Webmaster Tools → IndexNow
INDEXNOW_KEY=""

# ---- Cloudinary (Video compression & hosting) ----
# Sign up free at cloudinary.com → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ---- Analytics ----
GOOGLE_ANALYTICS_ID=""
