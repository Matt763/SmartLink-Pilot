# ============================================
# SMARTLINK PILOT — Environment Variables Template
# Copy to .env and fill in your values
# For Vercel: Add in Settings → Environment Variables
# ============================================

# ---- Authentication ----
NEXTAUTH_SECRET=""          # Generate: openssl rand -base64 32
NEXTAUTH_URL=""             # Your production URL, e.g. https://smartlinkpilot.com

# ---- Google OAuth ----
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---- Database (Vercel Postgres) ----
# Auto-filled by Vercel when you connect a Postgres database
POSTGRES_URL=""
POSTGRES_PRISMA_URL=""
POSTGRES_URL_NON_POOLING=""
POSTGRES_USER=""
POSTGRES_HOST=""
POSTGRES_PASSWORD=""
POSTGRES_DATABASE=""
DATABASE_URL=""
DIRECT_URL=""

# ---- Stripe ----
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PUBLISHABLE_KEY=""

# ---- OpenAI (Pilot Assistant Chat) ----
OPENAI_API_KEY=""

# ---- Google Analytics ----
GOOGLE_ANALYTICS_ID=""
