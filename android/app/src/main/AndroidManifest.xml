<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ═══════════════════════════════════════════════ -->
    <!--  PERMISSIONS                                    -->
    <!-- ═══════════════════════════════════════════════ -->

    <!-- Core network access -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Push notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Foreground service for clipboard monitoring -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- Keep screen on when shortening links -->
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />

    <!-- Draw over other apps — required for the floating URL bubble -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="false"
        android:hardwareAccelerated="true"
        android:largeHeap="true">

        <!-- ═══════════════════════════════════════════════ -->
        <!--  MAIN ACTIVITY                                  -->
        <!-- ═══════════════════════════════════════════════ -->
        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize">

            <!-- App launcher -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Deep linking — open smartlinkpilot.com links directly in app -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="smartlinkpilot.com" />
                <data android:scheme="https" android:host="www.smartlinkpilot.com" />
            </intent-filter>

            <!-- Custom URI scheme for in-app navigation -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="smartlinkpilot" />
            </intent-filter>

            <!-- Share intent — accept shared URLs from other apps -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>

        </activity>

        <!-- ═══════════════════════════════════════════════ -->
        <!--  CLIPBOARD MONITOR (floating bubble service)    -->
        <!-- ═══════════════════════════════════════════════ -->
        <service
            android:name=".ClipboardMonitorService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- ═══════════════════════════════════════════════ -->
        <!--  FIREBASE CLOUD MESSAGING                       -->
        <!-- ═══════════════════════════════════════════════ -->
        <service
            android:name="com.google.firebase.messaging.FirebaseMessagingService"
            android:exported="false">
            <intent-filter android:priority="-500">
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- Default FCM notification channel — link click alerts -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="link_clicks" />

        <!-- Default notification icon (white silhouette on coloured background) -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@mipmap/ic_launcher" />

        <!-- Brand accent colour for notification LED + icon tint -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_color"
            android:resource="@color/colorPrimary" />

        <!-- ═══════════════════════════════════════════════ -->
        <!--  FILE PROVIDER (required for Capacitor)         -->
        <!-- ═══════════════════════════════════════════════ -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
